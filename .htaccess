# ----------------------------------------------------------------------
# | Gzip / Deflate Compression                                         |
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    # Force compression for XML and HTML
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    
    # Decompress before storing on disk
    SetOutputFilter DEFLATE
</IfModule>

# ----------------------------------------------------------------------
# | Browser Caching (Expires Headers)                                  |
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 0 seconds"

    # CSS & JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"

    # Images & Media
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # Web Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------------
# | Prevent directory listings                                         |
# ----------------------------------------------------------------------
Options -Indexes

# ----------------------------------------------------------------------
# | Protect Sensitive Files (like .env, .gitignore, .git, db_setup)    |
# ----------------------------------------------------------------------
<FilesMatch "^(\.env|\.git|\.gitignore|db_setup\.php)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ----------------------------------------------------------------------
# | Prevent direct access to includes folder                           |
# ----------------------------------------------------------------------
RewriteEngine On

# Keep one public origin so links, analytics and ranking signals do not split.
RewriteCond %{HTTP_HOST} !^www\.rtchocos\.com$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://www.rtchocos.com%{REQUEST_URI} [R=301,L,NE]

# The home page canonical is the root URL.
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteRule ^includes/ - [F,L]
RewriteRule ^data/ - [F,L]

# ----------------------------------------------------------------------
# | Rewrite Rules for Sitemap & Blog Clean URLs                         |
# ----------------------------------------------------------------------
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Redirect blog/article.php?slug=xxx to clean url /blog/xxx (optional SEO improvement)
RewriteCond %{THE_REQUEST} \s/blog/article\.php\?slug=([^\s&]+)\s [NC]
RewriteRule ^blog/article\.php$ /blog/%1? [R=301,L]

# Rewrite clean blog URL to the actual router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/]+)$ blog/article.php?slug=$1 [L,QSA]

# ----------------------------------------------------------------------
# | Security Headers                                                   |
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-XSS-Protection "1; mode=block"
    <FilesMatch "^(api_.*|test_blog|router)\.php$">
        Header set X-Robots-Tag "noindex, nofollow"
    </FilesMatch>
</IfModule>
